# ── Server-only secrets (never prefixed with NEXT_PUBLIC_) ──────────
ADMIN_PASSWORD=changeme
COMPULIFE_AUTH_ID=your_compulife_auth_id
COMPULIFE_PROXY_URL=https://your-proxy.onrender.com/api
MEDICARE_PROXY_URL=https://your-proxy.onrender.com/medicare

# ── Client-safe keys (Supabase anon key is designed for browser use) ─
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Optional: debug logging to file (dev only, never in production) ─
# DEBUG_SESSION_LOG=1
